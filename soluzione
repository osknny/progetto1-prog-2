#include <stdio.h>
#include <ctype.h>

int stoib(char *s, unsigned short b, int *r);

static int fail(void) {
    printf("TEST FAILED\n");
    return 0;
}

static int run_case(char *s, unsigned short b, int expected_ret, int expected_value) {
    int out = 0x7f7f7f7f;
    int ret = stoib(s, b, &out);

    if (ret != expected_ret) return 0;
    if (expected_ret != 0 && out != expected_value) return 0;
    return 1;
}

static int run_null_s_case(unsigned short b) {
    int out = 0;
    return stoib(NULL, b, &out) == 0;
}

static int run_null_r_case(char *s, unsigned short b) {
    return stoib(s, b, NULL) == 0;
}

int main(void) {
    if (!run_case("   -1Axyz", 16, 6, -26)) return fail();
    if (!run_case("+10102", 2, 5, 10)) return fail();
    if (!run_case("Z", 36, 1, 35)) return fail();
    if (!run_case("12 34", 10, 2, 12)) return fail();
    if (!run_case("   +", 10, 0, 0)) return fail();
    if (!run_case("A", 10, 0, 0)) return fail();
    if (!run_case("10", 1, 0, 0)) return fail();
    if (!run_case("10", 37, 0, 0)) return fail();
    if (!run_null_s_case(10)) return fail();
    if (!run_null_r_case("10", 10)) return fail();
    if (!run_case("a", 16, 0, 0)) return fail();
    if (!run_case("-7", 10, 2, -7)) return fail();

    printf("TEST PASSED\n");
    return 0;
}

static int to_digit(unsigned char ch) {
    if (ch >= '0' && ch <= '9') return ch - '0';
    if (ch >= 'A' && ch <= 'Z') return 10 + (ch - 'A');
    return -1;
}

int stoib(char *s, unsigned short b, int *r) {
    if (s == NULL || r == NULL) return 0;
    if (b < 2 || b > 36) return 0;

    char *p = s;
    while (*p != '\0' && isspace((unsigned char)*p)) p++;

    int sign = 1;
    if (*p == '+' || *p == '-') {
        sign = (*p == '-') ? -1 : 1;
        p++;
    }

    int parsed = 0;
    int acc = 0;

    for (;;) {
        int d = to_digit((unsigned char)*p);
        if (d < 0 || d >= (int)b) break;

        acc = acc * (int)b + d;
        parsed = 1;
        p++;
    }

    if (!parsed) return 0;

    *r = sign * acc;
    return (int)(p - s);
}
